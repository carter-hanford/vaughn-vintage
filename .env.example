# Spotify Web API — https://developer.spotify.com/dashboard
# 1. Log in → Create app (any name; Redirect URI not required for this sync).
# 2. Open the app → copy Client ID → "View client secret" → copy secret.
# 3. Copy this file to ".env" (exact name; in Notepad use Save as type: All Files).
# 4. Paste values on the lines below (no spaces around =).
# 5. Run: npm run spotify:sync

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
